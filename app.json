{
  "expo": {
    "name": "POS-Estimation",
    "slug": "posestimation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.brightech.posestimation",
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#E6F4FE"
      }
    },

    "web": {
      "favicon": "./assets/icon.png"
    },

    "plugins": [
      "expo-sharing",
      "expo-font"
    ],

    "extra": {
      "eas": {
        "projectId": "57cc5910-fa80-487f-b77d-2ae6f71c6f34"
      }
    },

    "owner": "brightech"
  }
}